# Neon Postgres — primary datastore
# `vercel env pull .env.local` copies production values down locally.
DATABASE_URL=

# Upstash Redis — rate limiting + session-adjacent caches (optional, gracefully
# degrades if missing: rate limits are skipped, DB UNIQUE is still enforced).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# NextAuth / SIWE auth
# Generate a 32-byte hex secret:  openssl rand -hex 32
NEXTAUTH_SECRET=
# Canonical public URL. Use http://localhost:3000 for local dev.
NEXTAUTH_URL=http://localhost:3000

# WalletConnect project id — free at https://cloud.walletconnect.com
# Required for RainbowKit's mobile wallet flows. Public value, safe to commit.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Twitter OAuth 2.0 — created at https://developer.x.com (Basic tier $100/mo
# covers site auth + agent posting under the same project). Required for
# "Connect X" in the user flow.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# App-auth bearer token from the same X project. Used by the task verification
# and agent-engagement cron jobs to read public endpoints (likers, retweeters,
# agent's own activity). Separate from the user-OAuth creds above.
TWITTER_BEARER_TOKEN=

# Numeric X user id of the agent account (@ashborn_agent). Resolve it via
# `curl -H "Authorization: Bearer $TWITTER_BEARER_TOKEN" \
#   https://api.x.com/2/users/by/username/ashborn_agent`
# and paste the `data.id` value here. This ID drives the engagement cron
# (polls likes + retweets by the agent and awards bonuses to matched users).
AGENT_TWITTER_ID=

# Numeric X user id of the collection's official account (@survivorsoneth).
# Used by the follow-gate task verification. Same lookup pattern as above,
# just with the collection handle. Optional — the follow task verification
# can also resolve by handle at runtime if unset.
COLLECTION_TWITTER_ID=

# Shared secret so we can hit the /api/cron/* endpoints manually outside
# Vercel Cron. Vercel Cron traffic arrives with x-vercel-cron header; manual
# hits must send `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# Alchemy — used by the wallet-scoring pipeline (NFT holdings, floor prices,
# tx count, age). Free tier comfortably covers pre-launch traffic.
ALCHEMY_API_KEY=
